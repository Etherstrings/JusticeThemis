# Required for premium read routes
OVERNIGHT_PREMIUM_API_KEY=replace-with-premium-key

# Required for refresh/generate/readyz unless OVERNIGHT_ALLOW_UNSAFE_ADMIN=true
OVERNIGHT_ADMIN_API_KEY=replace-with-admin-key

# Local development only. Keep false or unset for self-hosted release.
OVERNIGHT_ALLOW_UNSAFE_ADMIN=false

# Optional SQLite path override.
# The variable name stays under the legacy OVERNIGHT_* contract in this soft-rename phase.
OVERNIGHT_NEWS_DB_PATH=data/overnight-news-handoff.db

# Optional search-discovery providers
BOCHA_API_KEYS=
TAVILY_API_KEYS=
SERPAPI_API_KEYS=
BRAVE_API_KEYS=

# Strongly recommended for complete market snapshot coverage.
# Without it, live runs may fall back to Treasury-only partial snapshots when Yahoo is rate-limited.
IFIND_REFRESH_TOKEN=

# Optional premium ticker enrichment provider.
# First pass keeps Alpha Vantage enrichment-only; it never blocks the core overnight board.
ALPHA_VANTAGE_API_KEY=
