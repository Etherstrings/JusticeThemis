# Required for premium read routes
OVERNIGHT_PREMIUM_API_KEY=replace-with-premium-key

# Required for refresh/generate/readyz unless OVERNIGHT_ALLOW_UNSAFE_ADMIN=true
OVERNIGHT_ADMIN_API_KEY=replace-with-admin-key

# Local development only. Keep false or unset for self-hosted release.
OVERNIGHT_ALLOW_UNSAFE_ADMIN=false

# Optional comma-separated frontend preview origins for standalone local UI work.
# By default the backend already allows http://127.0.0.1:5173 and http://localhost:5173.
OVERNIGHT_FRONTEND_ALLOWED_ORIGINS=

# Optional SQLite path override.
# The variable name stays under the legacy OVERNIGHT_* contract in this soft-rename phase.
OVERNIGHT_NEWS_DB_PATH=data/overnight-news-handoff.db

# Optional search-discovery providers
BOCHA_API_KEYS=
TAVILY_API_KEYS=
SERPAPI_API_KEYS=
BRAVE_API_KEYS=
AIHUBMIX_API_KEY=
# Optional AIHubMix overrides. The default chat-completions endpoint is https://aihubmix.com/v1/chat/completions
# and the default search-oriented model is gpt-4o-mini:surfing.
AIHUBMIX_BASE_URL=
AIHUBMIX_SEARCH_MODEL=

# Strongly recommended for complete market snapshot coverage.
# Without it, live runs may fall back to Treasury-only partial snapshots when Yahoo is rate-limited.
IFIND_REFRESH_TOKEN=

# Optional Polymarket prediction-market layer.
# Public read-only endpoints do not require an API key.
POLYMARKET_ENABLED=true
# Verified live examples on 2026-04-22:
# POLYMARKET_SIGNAL_CONFIG_JSON=[{"signal_key":"fed_apr_no_change","label":"2026年4月FOMC不变","event_slug":"fed-decision-in-april","market_question_contains":"no change in Fed interest rates","outcome":"Yes","bucket":"macro_rates"},{"signal_key":"fed_2026_zero_cuts","label":"2026年零次降息","event_slug":"how-many-fed-rate-cuts-in-2026","market_question_contains":"no Fed rate cuts happen in 2026","outcome":"Yes","bucket":"macro_rates"},{"signal_key":"fed_emergency_cut_before_2027","label":"2026年前联储紧急降息","event_slug":"fed-emergency-rate-cut-before-2027","outcome":"Yes","bucket":"macro_rates"}]
POLYMARKET_SIGNAL_CONFIG_JSON=

# Optional Kalshi prediction-market layer.
KALSHI_ENABLED=true
# Verified live examples on 2026-04-22:
# KALSHI_SIGNAL_CONFIG_JSON=[{"signal_key":"us_recession_2026","label":"2026美国衰退概率","event_ticker":"KXRECSSNBER-26","bucket":"macro_growth"},{"signal_key":"fed_cut_before_2027","label":"2026年前美联储降息概率","event_ticker":"KXRATECUT-26DEC31","bucket":"macro_rates"},{"signal_key":"fed_large_cut_2026","label":"2026年超25bp降息概率","event_ticker":"KXLARGECUT-26","bucket":"macro_rates"}]
KALSHI_SIGNAL_CONFIG_JSON=

# Optional CME FedWatch layer. Public read-only, but source-side anti-bot controls may block some IPs.
CME_FEDWATCH_ENABLED=true

# Optional CFTC COT positioning layer.
CFTC_ENABLED=true
# Example:
# CFTC_SIGNAL_CONFIG_JSON=[{"signal_key":"gold_cot","label":"黄金 COT","commodity_name":"GOLD","bucket":"precious_metals"}]
CFTC_SIGNAL_CONFIG_JSON=

# Optional premium ticker enrichment provider.
# First pass keeps Alpha Vantage enrichment-only; it never blocks the core overnight board.
ALPHA_VANTAGE_API_KEY=
